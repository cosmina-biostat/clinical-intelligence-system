# Trained models — commit small ones, exclude large RF (191 MB)
models/saved/random_forest_cardio.pkl

# Local training recipes — reference only, not needed on GitHub
scripts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Reports output
reports/figures/*
!reports/figures/.gitkeep

# API keys — NEVER commit these
.env
*.key
.env
