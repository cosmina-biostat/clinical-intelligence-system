# Data — never commit raw data to GitHub
data/raw/*
data/processed/*
data/synthetic/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep

# Trained models — too large for GitHub
models/saved/*
!models/saved/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Reports output
reports/figures/*
!reports/figures/.gitkeep

# API keys — NEVER commit these
.env
*.key
